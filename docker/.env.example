# Camera Brain Docker Configuration
# Copy to .env and customize

# ============================================================================
# Database Configuration
# ============================================================================
DB_USER=camera_brain
DB_PASSWORD=change_me_in_production_use_random_string
DB_NAME=camera_brain
DB_PORT=5432

# ============================================================================
# Model Configuration
# ============================================================================
# Path to models directory on host system
MODEL_DIR=/path/to/your/models

# Model filenames (must exist in MODEL_DIR)
LLAMA_MODEL=LFM2.5-VL-1.6B.Q8_0.gguf
LLAMA_MMPROJ=LFM2.5-VL-1.6B.mmproj-f16.gguf

# ============================================================================
# CPU/Memory Tuning
# ============================================================================
CPU_THREADS=4

# ============================================================================
# Service Ports
# ============================================================================
VLM_PORT=8081
QUERY_PORT=8082
GATEWAY_PORT=8080

# ============================================================================
# Data Directory (for worker storage)
# ============================================================================
DATA_DIR=./data

# ============================================================================
# Grafana (Optional)
# ============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
